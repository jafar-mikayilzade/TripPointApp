SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
GOOGLE_PLACES_API_KEY=
OPENWEATHER_API_KEY=
# Optional: tips for POST /api/plan-route (itinerary works without it)
ANTHROPIC_API_KEY=
# mock | osm | google | hybrid
# hybrid = Google (restaurant/hotel/…) + OSM (nature/waterfall/historical/…)
DATA_SOURCE=hybrid
# Optional: comma-separated Overpass mirrors
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter,https://overpass.openstreetmap.fr/api/interpreter
